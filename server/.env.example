# ============================================
# TalentHive Server - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.
# Lines marked [REQUIRED] must be set for the server to start.
# Lines marked [OPTIONAL] have fallbacks or are for specific features.

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ============================================
# DATABASE [REQUIRED]
# ============================================
# MongoDB connection string - server will NOT start without this
MONGODB_URI=mongodb://localhost:27017/talenthive
MONGODB_TEST_URI=mongodb://localhost:27017/talenthive_test

# ============================================
# AUTHENTICATION [REQUIRED]
# ============================================
# JWT secrets - must be set for auth to work
# In production, use strong random strings (32+ characters)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# REDIS [OPTIONAL]
# ============================================
# Redis is optional - server works without it (no caching)
# Uncomment and configure if you have Redis running
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ============================================
# EMAIL [OPTIONAL]
# ============================================
# Email is optional in development - verification emails are auto-skipped
# Set one of these if you want email functionality to work
# RESEND_API_KEY=re_your_resend_api_key
# EMAIL_FROM=TalentHive <onboarding@resend.dev>
# SENDGRID_API_KEY=your-sendgrid-api-key

# ============================================
# FILE UPLOADS [OPTIONAL]
# ============================================
# Cloudinary is optional - file uploads won't work without it
# but the server will still start and run
# CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
# CLOUDINARY_API_KEY=your-cloudinary-api-key
# CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================
# PAYMENTS [OPTIONAL in development]
# ============================================
# Stripe is optional in development - payment features won't work
# but the server will still start
# STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ============================================
# SECURITY
# ============================================
BCRYPT_ROUNDS=12

# Rate Limiting (set high for development)
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=10000000
DISABLE_RATE_LIMIT_FOR_TESTING=true

# ============================================
# CORS [REQUIRED for frontend connection]
# ============================================
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============================================
# SOCKET.IO
# ============================================
SOCKET_CORS_ORIGIN=http://localhost:3000
